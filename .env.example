# Google Gemini API key — get one at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_key_here

# Optional: override the generation model.
# Default is gemini-2.5-flash (best quality). The free tier allows only ~20
# requests/day for that model, so on a free key use the higher-quota lite model:
# GEMINI_MODEL=gemini-2.5-flash-lite

# Anthropic Claude API key (fallback provider #2) — https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_key_here

# Groq API key (fallback provider #3, llama-3.3-70b-versatile) — https://console.groq.com/
# GROQ_API_KEY=your_key_here

# LLM provider fallback order — comma-separated list of: gemini, claude, groq.
# The app tries each in order; on failure it falls through to the next.
# Embeddings always use Gemini regardless of this setting.
# LLM_PROVIDER_ORDER=gemini,claude,groq
