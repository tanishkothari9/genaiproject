# Google Gemini API key — get one at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_key_here

# Optional: override the generation model.
# Default is gemini-2.5-flash (best quality). The free tier allows only ~20
# requests/day for that model, so on a free key use the higher-quota lite model:
# GEMINI_MODEL=gemini-2.5-flash-lite
